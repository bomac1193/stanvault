# Database
# SQLite (local development)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/imprint?schema=public"

# NextAuth.js
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3003"

# OAuth (optional for MVP - mock auth works without these)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Spotify API (for real fan data integration)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_ARTIST_REDIRECT_URI="http://localhost:3003/api/auth/spotify/callback"
SPOTIFY_FAN_REDIRECT_URI="http://localhost:3003/api/fan/auth/spotify/callback"

# App URL (for OAuth callbacks)
APP_URL="http://localhost:3003"

# Future provider OAuth
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_ARTIST_REDIRECT_URI="http://localhost:3003/api/auth/youtube/callback"
YOUTUBE_FAN_REDIRECT_URI="http://localhost:3003/api/fan/auth/youtube/callback"
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_ARTIST_REDIRECT_URI="http://localhost:3003/api/auth/twitch/callback"
TWITCH_FAN_REDIRECT_URI="http://localhost:3003/api/fan/auth/twitch/callback"
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_ARTIST_REDIRECT_URI="http://localhost:3003/api/auth/discord/callback"
DISCORD_FAN_REDIRECT_URI="http://localhost:3003/api/fan/auth/discord/callback"

# Emissar integration (campaign delivery proxy)
EMISSAR_API_URL="http://localhost:3004"

# Mapbox (optional — enables fan heatmap on FanPrint page)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Ecosystem API (for cross-app communication)
ECOSYSTEM_API_SECRET=""

# Admin/testing controls
# Set true to allow logged-in users to edit their pricing tier from Settings.
ENABLE_PRICING_TIER_OVERRIDE="false"
# Comma-separated admin emails allowed to override tier when ENABLE_PRICING_TIER_OVERRIDE is false.
ADMIN_EMAILS=""
